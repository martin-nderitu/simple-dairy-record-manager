{{> milk_collectors_nav }}

<div class="row justify-content-center pt-3">
    <div class="card col-md-5">
        <div class="card-header">
            <h4 class="text-center">Add record</h4>
            {{> alerts }}
        </div>
        <div class="card-body">
            <form action="/milk-collectors/record/add" method="POST">
                <div class="form-group">
                    <label class="sr-only" for="farmerId">Farmer id</label>
                    <input type="number" class="form-control" name="farmerId"
                           placeholder="Please enter farmer id"
                           value="{{#if body.farmerId }}{{ body.farmerId }}{{/if}}"
                           aria-describedby="id-error" required>
                    <span class="form-text text-danger"
                          id="id-error">{{#if errors.farmerId }}{{errors.farmerId }}{{/if}}</span>
                </div>

                <div class="form-group">
                    <label for="amount">Milk delivered (litres)</label>
                    <input type="number" class="form-control" id="amount" name="amount"
                           placeholder="Please enter amount of milk delivered in litres"
                           value="{{#if body.amount }}{{ body.amount }}{{/if}}"
                           min="0" step="0.01"
                           aria-describedby="amount-error"
                           required>
                    <span id="amount-error"
                          class="form-text text-danger">{{#if errors.amount }}{{ errors.amount }}{{/if}}</span>
                </div>

                <div class="form-group">
                    <label for="shift">Shift</label>
                    <select class="form-control" id="shift" name="shift" required>
                        <option value="">---------</option>
                        <option value="morning">Morning</option>
                        <option value="afternoon">Afternoon</option>
                        <option value="evening">Evening</option>
                    </select>
                    <span class="form-text text-danger">{{#if errors.shift }}{{ errors.shift }}{{/if}}</span>
                </div>

                <div class="form-group">
                    <button type="submit" class="btn btn-primary">Submit</button>
                </div>
            </form>
        </div>
    </div>
</div>

{{> scripts }}

<script>
    const shift = `{{body.shift}}` || undefined;
    if (shift) { $("#shift").val(shift);}
</script>

{{> footer }}